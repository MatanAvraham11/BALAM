OPENAI_API_KEY=
APP_PASSWORD=
# Required for /api/login cookie and Next.js middleware (same value in Vercel env for Python + Node)
APP_SESSION_SECRET=
# Rafael V.5.9 buyer name: OCR.space API (https://api.ocr.space/parse/image, language=heb).
# Set OCR_SPACE_API_KEY on the **Python** runtime (Vercel serverless / Fly worker), not only in Next.js — the parser runs in Python.
# OCR_SPACE_API_KEY=
# Optional: set to 0/false/off to disable buyer OCR (buyer_name becomes "OCR Failed"; API still returns buyer_ocr_reason).
# RAFAEL_BUYER_OCR=
#   python3 api/check_rafael_ocr_env.py
# See docs/rafael-buyer-ocr.md
#
# Optional: override path for submission-deadline debug crop (default ``debug_date_crop.png``).
# RAFAEL_OCR_DEBUG_DATE_PATH=/tmp/date.png
#
# Optional: Rafael Python worker URL (same FastAPI; no local Tesseract required since V.5.9).
# RAFAEL_BOM_WORKER_URL=https://your-app.fly.dev
#
# Local next dev + uvicorn on another port (e.g. 8000):
# PYDEV_API_BASE_URL=http://127.0.0.1:8000
