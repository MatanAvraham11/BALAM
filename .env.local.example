OPENAI_API_KEY=
APP_PASSWORD=
# Required for /api/login cookie and Next.js middleware (same value in Vercel env for Python + Node)
APP_SESSION_SECRET=
# Rafael V.5.7 buyer name uses Tesseract (heb) on the Python API host. Vercel serverless usually has no
# tesseract binary — expect buyer_ocr_ready=false and a Hebrew UI hint unless you use Docker/worker OCR.
# Optional: absolute path to tesseract when it is installed but not on PATH (IDE, systemd, some hosts).
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
# RAFAEL_TESSERACT_CMD=/opt/homebrew/bin/tesseract
# Optional: set to 0/false/off to disable buyer OCR (buyer_name becomes "OCR Failed"; API still returns buyer_ocr_reason).
# RAFAEL_BUYER_OCR=
# Verify locally: `which tesseract` and `tesseract --list-langs` (must include heb), then:
#   python3 api/check_rafael_ocr_env.py
# See docs/rafael-buyer-ocr.md and docs/plan-rafael-tesseract-production.md
#
# Rafael Docker worker (Tesseract on Fly/Railway/…): set on Vercel + worker the same APP_SESSION_SECRET.
# RAFAEL_BOM_WORKER_URL=https://your-app.fly.dev
#
# Local next dev + uvicorn on another port (e.g. 8000):
# PYDEV_API_BASE_URL=http://127.0.0.1:8000
